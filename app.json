{
  "expo": {
    "name": "Money Manager",
    "slug": "money-manager",
    "version": "1.0.0",
    "orientation": "portrait",
    "platforms": [
      "android",
      "ios",
      "web"
    ],
    "icon": "./assets/images/splash-logo-white.png",
    "scheme": [
      "com.billiatkachembo.moneymanager",
      "moneymanager"
    ],
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "backgroundColor": "#667eea"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.billiatkachembo.moneymanager"
    },
    "android": {
      "package": "com.billiatkachembo.moneymanager",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/splash-logo-white.png",
        "backgroundColor": "#F7EEE4"
      },
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "@react-native-community/datetimepicker",
      [
        "expo-image-picker",
        {
          "photosPermission": "The app accesses your photos to let you add receipt images.",
          "cameraPermission": "The app needs access to your camera to take photos of receipts."
        }
      ],
      "expo-web-browser",
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "d2f7f5bf-b64f-4703-b41c-9a258f1f9521"
      }
    }
  }
}
